{
  "_about": "value_check 领域规则·示意样例(表名/字段名均为占位,非任何具体项目)。规则类型/字段见 value_check.py 顶部说明;实际项目按本结构在配置目录建 <系统>.checks.json。",
  "rules": [
    {
      "type": "cardinality",
      "severity": "advisory",
      "desc": "示意:进化链成员数-1 vs 该品质可进化次数。若运行时恒以品质封顶、链超出=有意补全(超出成员不可达),则仅 advisory 提示(非 major 阻断),供设计者核对是否真想留不可达成员",
      "array_table": "evolveLine",
      "array_field": "unit",
      "member_table": "unit",
      "member_rarity_field": "rarity",
      "limit_table": "rarityCap",
      "limit_field": "evolution"
    },
    {
      "type": "coverage",
      "desc": "示意:等级表 id 连续覆盖 1~200,无断档",
      "table": "levelTable",
      "field": "id",
      "min": 1,
      "max": 200
    },
    {
      "type": "monotonic",
      "desc": "示意:升级三围加成随等级单调不减(累计值)",
      "table": "levelTable",
      "field": "HpPercentage",
      "order_field": "id"
    },
    {
      "type": "monotonic",
      "desc": "示意:升星三围加成随星级单调不减(同品质+同元素分组)",
      "table": "starTable",
      "field": "HpPercentage",
      "order_field": "star",
      "group_fields": ["rarity", "element"]
    }
  ]
}
